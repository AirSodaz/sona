{
  "name": "sona",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "scripts": {
    "dev": "pnpm --filter sona-desktop-frontend run dev",
    "prepare": "husky",
    "build": "pnpm --filter sona-desktop-frontend run build",
    "build:sona-cli": "cargo build -p sona-cli --release",
    "generate:desktop-bindings": "cargo run -p sona-ts-bind --example export_desktop_bindings",
    "lint": "pnpm --filter sona-desktop-frontend run lint",
    "lint:ci": "pnpm --filter sona-desktop-frontend run lint:ci",
    "lint:staged": "node scripts/check-staged.js",
    "preview": "pnpm --filter sona-desktop-frontend run preview",
    "test": "pnpm --filter sona-desktop-frontend run test",
    "test:ci": "pnpm --filter sona-desktop-frontend run test:ci",
    "tauri": "node platforms/desktop/scripts/tauri.js",
    "build:ci": "pnpm run build",
    "test:scripts": "node --test --test-concurrency=1 scripts/*.test.js",
    "ci:pr": "pnpm run lint:ci && pnpm run test:ci && pnpm run test:scripts && pnpm run build:ci",
    "verify:tauri-bundle": "pnpm --filter sona-desktop-frontend run verify:tauri-bundle",
    "verify:android-uniffi": "node scripts/verify-uniffi-android-sample.js",
    "verify:android-uniffi:gradle": "node scripts/verify-uniffi-android-sample.js --download-gradle --require-gradle",
    "verify:android-client": "node scripts/verify-android-client.js",
    "commitlint": "commitlint --edit",
    "check:staged": "node scripts/check-staged.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{cjs,css,html,js,json,jsx,md,mjs,ps1,rs,sh,ts,tsx,toml,yaml,yml}": "pnpm run lint:staged --"
  }
}
