{
  "name": "tauri-appsona",
  "private": true,
  "version": "0.6.5",
  "type": "module",
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "dev": "vite",
    "prepare": "husky",
    "prebuild": "node scripts/setup-ffmpeg.js",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings=0",
    "lint:staged": "node scripts/check-staged.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest --run",
    "tauri": "node scripts/tauri.js",
    "build:ci": "pnpm run build",
    "ci:pr": "pnpm run lint:ci && pnpm run test:ci && pnpm run build:ci",
    "verify:cli-bundle": "node scripts/verify-cli-bundle.js",
    "commitlint": "commitlint --edit",
    "check:staged": "node scripts/check-staged.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2",
    "@tauri-apps/plugin-log": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-store": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.6",
    "react-virtuoso": "^4.18.1",
    "recharts": "^3.8.1",
    "uuid": "^14.0.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.1",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "ffmpeg-static": "^5.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{cjs,css,html,js,json,jsx,md,mjs,ps1,rs,sh,ts,tsx,toml,yaml,yml}": "pnpm run lint:staged --"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "ffmpeg-static"
    ]
  }
}
