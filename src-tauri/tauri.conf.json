{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sona",
  "version": "0.8.0",
  "identifier": "com.asoda.sona",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sona - Transcript Editor",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:*; object-src 'none'; base-uri 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPLOCALDATA/history",
          "$APPLOCALDATA/history/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/cli/*",
      "resources/shared_libs/*"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "targets": [
      "app",
      "nsis",
      "deb",
      "appimage",
      "rpm",
      "dmg",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "windowPosition": {
          "x": 400,
          "y": 400
        },
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBRjZCREYyRkM4QUU4NEIKUldSTDZJcjg4cjMyS3ZDb3d0Ry9adnE5TWoyN1FMeSsyMEFTUDdObVNtQnZuR1dnV3EwSVNETy8K",
      "endpoints": [
        "https://github.com/AirSodaz/sona/releases/latest/download/updater.json"
      ]
    }
  }
}
